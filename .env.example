# =====================================================
# Nexus AI — Environment Variables
# Copy to `.env.local` for local development.
# All NEXT_PUBLIC_* values are exposed to the browser.
# =====================================================

# ----- Supabase -----------------------------------------------------------
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (do NOT prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- AI Provider --------------------------------------------------------
# Vercel AI Gateway routes by model id. See: https://sdk.vercel.ai/providers
# When deployed on Vercel, the platform injects AI_GATEWAY_API_KEY automatically.
AI_GATEWAY_API_KEY=

# Optional: direct provider keys (used as fallback when AI Gateway is absent)
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ----- Site Config --------------------------------------------------------
# Canonical site origin (no trailing slash). Used for OG, sitemap, JSON-LD.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----- Analytics (optional) ----------------------------------------------
# Vercel Analytics is auto-enabled when deployed to Vercel.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ----- Email (optional) ---------------------------------------------------
# Used by /api/contact for transactional inquiries.
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@techtideai.io

# ----- Rate Limiting (optional, recommended for production) --------------
# Upstash Redis — free tier is plenty for marketing site use.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
